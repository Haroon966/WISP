{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wisp",
  "version": "0.1.0",
  "identifier": "com.olufsen.wisp",
  "build": {
    "beforeDevCommand": "npm run install:dev-desktop && npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "label": "main",
        "title": "Wisp",
        "width": 800,
        "height": 600,
        "center": true,
        "visible": true,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#0f172a"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
